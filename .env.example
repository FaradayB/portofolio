# --- Google AI Studio (LLM + embeddings) ---
# https://aistudio.google.com/app/apikey
# Read by api/chat.py (Vercel env var) and rag/ingest.py (GitHub Actions secret).
GEMINI_API_KEY=

# --- Pinecone (vector store) ---
# https://app.pinecone.io  → API Keys
# Create a serverless index with dimension=768, metric=cosine (matches
# Google text-embedding-004). Set the same key in Vercel env AND as a
# GitHub Actions repo secret.
PINECONE_API_KEY=
# Name of the Pinecone index to upsert to / query (default: cv-rag).
PINECONE_INDEX=cv-rag

# Never commit real keys.
